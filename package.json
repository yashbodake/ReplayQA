{
  "name": "replayqa",
  "version": "0.1.0",
  "description": "Playwright-based QA framework for collecting execution artifacts and generating HTML reports",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "replay": "npx tsx src/cli/run.ts",
    "discover": "npx tsx src/discovery/cli/run.ts",
    "fingerprint": "npx tsx src/discovery/state-lab/cli.ts",
    "fingerprint:lab": "npx tsx src/discovery/state-lab/experiment.ts",
    "reason": "npx tsx src/discovery/reasoning-lab/cli.ts",
    "plan": "npx tsx src/discovery/qa-planning-lab/cli.ts",
    "replayqa": "npx tsx src/discovery/run/cli.ts",
    "reliability": "npx tsx src/discovery/run/reliability/benchmark.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "playwright",
    "qa",
    "testing",
    "artifacts",
    "reporting"
  ],
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^20.14.0",
    "tsx": "^4.23.1",
    "typescript": "^5.5.0"
  },
  "dependencies": {
    "playwright": "^1.61.1"
  }
}
