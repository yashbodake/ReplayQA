{
  "outputDir": "./artifacts",
  "artifacts": {
    "videos": true,
    "screenshots": true,
    "traces": true,
    "consoleLogs": true,
    "networkLogs": true
  },
  "playwright": {
    "testDir": "./tests",
    "retries": 0,
    "workers": "auto"
  },
  "discovery": {
    "targetUrl": "https://phone-book-yrap.vercel.app/",
    "credentials": {
      "username": "${REPLAYQA_DISCOVERY_USERNAME}",
      "password": "${REPLAYQA_DISCOVERY_PASSWORD}"
    }
  }
}
